{
  "name": "hudu-mcp-all",
  "version": "0.1.0",
  "description": "Full-coverage Hudu MCP server. Generates MCP tools dynamically from the official Hudu Swagger spec — every documented endpoint, R/W.",
  "type": "module",
  "bin": {
    "hudu-mcp-all": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "swagger.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "list-tools": "tsx src/list-tools.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hudu",
    "documentation",
    "msp",
    "it-documentation",
    "ai"
  ],
  "author": "peetinc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peetinc/hudu-mcp-all.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
