# Hudu base URL — example: https://yourorg.huducloud.com/api/v1
HUDU_BASE_URL=https://yourorg.huducloud.com/api/v1

# API key — get from Hudu Admin > API Keys
# Either set HUDU_API_KEY directly OR put the key in a file and set HUDU_API_KEY_FILE
HUDU_API_KEY=

# Optional: path to file containing the API key (default: ~/.hudukey if exists)
HUDU_API_KEY_FILE=

# Optional: override bundled swagger.json
HUDU_SWAGGER_PATH=

# Optional: comma-separated operationIds to disable (e.g. "delete_companies_id,delete_articles_id")
HUDU_DISABLED_OPERATIONS=

# Optional: block all DELETE operations
HUDU_READONLY=false

# Optional: request timeout in ms (default 30000)
HUDU_TIMEOUT_MS=30000

# Optional: max retries on HTTP 429 (default 3). Respects Retry-After header.
HUDU_MAX_RETRIES=3

# Optional: max response body size in bytes; larger responses are truncated to prevent context blow-up (default 1500000)
HUDU_MAX_RESPONSE_BYTES=1500000
